# Medico HMS — Environment Variables
# Copy this file to .env and update values

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_SETTINGS_MODULE=medico.settings.dev

# PostgreSQL Database
DB_NAME=medico
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Field-level Encryption Key (Fernet, 32 bytes base64)
FIELD_ENCRYPTION_KEY=change-me-in-production-32-byte-key-here!

# Redis (Celery broker)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
